<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>SMRUCC.genomics.Annotation.Prodigal</RootNamespace>
    <AssemblyName>SMRUCC.genomics.Annotation.Prodigal</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <OptionStrict>Off</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <OptionInfer>On</OptionInfer>
    <Description>Prodigal (PROkaryotic DYnamic programming Gene-finding ALgorithm)</Description>
    <Version>1.0.0</Version>
    <Platforms>AnyCPU;x64</Platforms>
    <AssemblyTitle>Prodigal (PROkaryotic DYnamic programming Gene-finding ALgorithm)</AssemblyTitle>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>Prodigal</Title>
    <IncludeSymbols>True</IncludeSymbols>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\runtime\sciBASIC#\Microsoft.VisualBasic.Core\src\Core.vbproj" />
    <ProjectReference Include="..\..\..\core\Bio.Annotation\annotation.NET5.vbproj" />
    <ProjectReference Include="..\..\..\core\Bio.Assembly\biocore-netcore5.vbproj" />
  </ItemGroup>

</Project>
