<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>SMRUCC.genomics.Analysis.HTS</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>SMRUCC.genomics.Analysis.HTS.RNAExpression</AssemblyName>
    <AssemblyTitle>Convert the RNA-seq feature count to expression matrix data</AssemblyTitle>
    <Platforms>AnyCPU;x64</Platforms>
    <Configurations>Debug;Release;Rsharp_app_release</Configurations>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\interops\RNA-Seq\RNA-seq.Data\RNA-seq.Data.NET5.vbproj" />
    <ProjectReference Include="..\..\HTS_matrix\HTS_matrix-netcore5.vbproj" />
  </ItemGroup>

</Project>
